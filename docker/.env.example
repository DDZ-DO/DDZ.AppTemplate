# ===========================================
# DDZ.__AppName__ - Production Environment
# Kopiere diese Datei nach .env und setze die Werte
# ===========================================

# JWT Secret (mindestens 32 Zeichen)
DDZ_JWT_SECRET=change-me-to-a-secure-random-string-min-32-chars

# PostgreSQL (zentrale Instanz auf ddz-net)
POSTGRES_HOST=postgres
POSTGRES_DB=ddz-__appname__
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-secure-password

# NATS (extern auf ddz-net, Standard passt fuer docker-server)
# NATS_URL=nats://nats:4222
